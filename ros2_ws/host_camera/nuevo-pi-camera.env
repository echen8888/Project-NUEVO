# Project NUEVO native Raspberry Pi camera defaults.
#
# This file is installed to /etc/default/nuevo-pi-camera by install.sh.
# Edit the installed copy on the Pi host, then restart:
#   sudo systemctl restart nuevo-pi-camera-feed

NUEVO_CAMERA_DEVICE=/dev/video10
NUEVO_CAMERA_VIDEO_NR=10
NUEVO_CAMERA_CARD_LABEL="NUEVO Pi Camera"

NUEVO_CAMERA_WIDTH=1280
NUEVO_CAMERA_HEIGHT=720
NUEVO_CAMERA_FPS=15
NUEVO_CAMERA_PIXEL_FORMAT=YUYV

# First implementation target: rpicam-vid MJPEG into ffmpeg YUYV output.
# If hardware testing shows GStreamer is more stable, only the feed wrapper
# should need to change.
NUEVO_CAMERA_PRODUCER=rpicam_ffmpeg_yuyv
