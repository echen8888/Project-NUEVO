#!/usr/bin/env bash
set -Eeuo pipefail

env_file="${NUEVO_CAMERA_ENV_FILE:-/etc/default/nuevo-pi-camera}"
if [[ -r "$env_file" ]]; then
    # shellcheck disable=SC1090
    source "$env_file"
fi

: "${NUEVO_CAMERA_DEVICE:=/dev/video10}"
: "${NUEVO_CAMERA_VIDEO_NR:=10}"
: "${NUEVO_CAMERA_CARD_LABEL:=NUEVO Pi Camera}"
: "${NUEVO_CAMERA_WIDTH:=1280}"
: "${NUEVO_CAMERA_HEIGHT:=720}"
: "${NUEVO_CAMERA_FPS:=15}"
: "${NUEVO_CAMERA_PIXEL_FORMAT:=YUYV}"
: "${NUEVO_CAMERA_PRODUCER:=rpicam_ffmpeg_yuyv}"

log() {
    printf '[nuevo-pi-camera] %s\n' "$*"
}

die() {
    printf '[nuevo-pi-camera] ERROR: %s\n' "$*" >&2
    exit 1
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "$1 is not installed"
}

require_cmd rpicam-vid
require_cmd ffmpeg

if [[ ! -c "$NUEVO_CAMERA_DEVICE" ]]; then
    log "$NUEVO_CAMERA_DEVICE is missing; trying to load v4l2loopback"
    modprobe v4l2loopback \
        video_nr="$NUEVO_CAMERA_VIDEO_NR" \
        card_label="$NUEVO_CAMERA_CARD_LABEL" \
        exclusive_caps=1 \
        max_buffers=4 || true
fi

for _ in {1..20}; do
    [[ -c "$NUEVO_CAMERA_DEVICE" ]] && break
    sleep 0.25
done

[[ -c "$NUEVO_CAMERA_DEVICE" ]] || die "$NUEVO_CAMERA_DEVICE is not available"

case "$NUEVO_CAMERA_PRODUCER" in
    rpicam_ffmpeg_yuyv)
        log "feeding $NUEVO_CAMERA_DEVICE at ${NUEVO_CAMERA_WIDTH}x${NUEVO_CAMERA_HEIGHT}@${NUEVO_CAMERA_FPS} as $NUEVO_CAMERA_PIXEL_FORMAT"
        rpicam-vid \
            --nopreview \
            --width "$NUEVO_CAMERA_WIDTH" \
            --height "$NUEVO_CAMERA_HEIGHT" \
            --framerate "$NUEVO_CAMERA_FPS" \
            --codec mjpeg \
            --timeout 0 \
            --output - |
        ffmpeg \
            -nostdin \
            -loglevel warning \
            -re \
            -f mjpeg \
            -i pipe:0 \
            -vf "scale=${NUEVO_CAMERA_WIDTH}:${NUEVO_CAMERA_HEIGHT},format=yuyv422" \
            -vcodec rawvideo \
            -pix_fmt yuyv422 \
            -f v4l2 \
            "$NUEVO_CAMERA_DEVICE"
        ;;
    *)
        die "unsupported NUEVO_CAMERA_PRODUCER=$NUEVO_CAMERA_PRODUCER"
        ;;
esac
